<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>פורטל למידה אישי</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 100%); font-family: 'Segoe UI', sans-serif; min-height: 100vh; margin: 0; }
        
        .header-section { 
            background: linear-gradient(to right, #3f51b5, #5a67d8); 
            color: white; 
            padding: 40px 20px; 
            text-align: center; 
            border-radius: 0 0 50px 50px; 
            position: relative; 
            margin-bottom: 40px; 
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        .logout-btn { position: absolute; top: 20px; left: 20px; background: rgba(255, 255, 255, 0.2); color: white; border: 1px solid white; padding: 5px 15px; border-radius: 50px; cursor: pointer; text-decoration: none; font-size: 0.8rem; }
        .add-btn { position: absolute; top: 20px; right: 20px; background: #fff; color: #3f51b5; border: none; padding: 8px 18px; border-radius: 50px; cursor: pointer; font-weight: bold; text-decoration: none; }

        .lessons-grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); 
            gap: 30px; 
            padding-bottom: 50px;
        }
        .lesson-card { 
            background: white; 
            border-radius: 25px; 
            padding: 35px; 
            border-right: 10px solid #3f51b5; 
            box-shadow: 0 15px 30px rgba(0,0,0,0.08); 
            position: relative; 
            transition: transform 0.2s;
        }
        .lesson-card:hover { transform: translateY(-5px); }
        
        .status-badge { 
            position: absolute; 
            top: 20px; 
            left: 20px; 
            padding: 6px 16px; 
            border-radius: 50px; 
            font-size: 0.85rem; 
            font-weight: bold; 
        }
        .status-pending { background: #fffbeb; color: #b45309; }
        .status-active { background: #f0fdf4; color: #15803d; }

        .price-tag { color: #3f51b5; font-weight: bold; font-size: 1.2rem; margin-top: 10px; display: block; }
    </style>
</head>
<body>
    <div class="header-section">
        <div onclick="logout()" class="logout-btn">יציאה</div>
        <a href="/lessons/add" class="add-btn">+ הוסף שיעור</a>
        
        <h1 class="fw-bold mb-1">פורטל למידה אישי</h1>
        <p class="mb-3" style="opacity: 0.9;">כל השיעורים והבקשות במקום אחד</p>
        
        <div class="badge bg-light text-primary px-4 py-2 rounded-pill shadow-sm">
            שלום <span id="userNameDisplay"></span> | סטטוס: <span id="userRoleDisplay"></span>
        </div>
    </div>

    <div class="container">
        <div id="lessonsContainer" class="lessons-grid">
            </div>
    </div>

    <script>
        const token = sessionStorage.getItem("token");
        const role = sessionStorage.getItem("role");
        const username = sessionStorage.getItem("username");

        if (!token) window.location.href = "/auth/login";

        document.getElementById("userNameDisplay").innerText = username;
        document.getElementById("userRoleDisplay").innerText = role === 'admin' ? 'מורה' : 'תלמיד';

        async function loadLessons() {
            try {
                const res = await fetch("/lessons/api/all", {
                    headers: { "Authorization": "Bearer " + token }
                });
                
                if (res.status === 401) logout();
                
                const lessons = await res.json();
                const container = document.getElementById("lessonsContainer");
                
                container.innerHTML = lessons.map(l => `
                    <div class="lesson-card">
                        <div class="status-badge ${l.status === 'active' ? 'status-active' : 'status-pending'}">
                            ${l.status === 'active' ? 'מאושר' : 'ממתין'}
                        </div>
                        <div style="font-size:1.8rem; font-weight:bold; color:#1a237e; margin-bottom: 10px;">${l.subject}</div>
                        <p class="text-muted mb-4">מזמין השיעור: <strong class="text-dark">${l.studentName}</strong></p>
                        
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="price-tag">₪${l.price || '0'}</span>
                            <div>
                                <a href="/lessons/${l._id}" class="btn btn-primary rounded-pill px-4">פרטים</a>
                                ${role === 'admin' ? `<button onclick="deleteLesson('${l._id}')" class="btn btn-link text-danger text-decoration-none ms-2">מחק</button>` : ''}
                            </div>
                        </div>
                    </div>
                `).join('');
            } catch (err) {
                console.error("שגיאה בטעינת שיעורים");
            }
        }

       
        async function deleteLesson(id) {
            try {
                await fetch(`/lessons/${id}`, { 
                    method: 'DELETE', 
                    headers: { "Authorization": "Bearer " + token } 
                });
                loadLessons(); 
            } catch (err) {
                console.error("שגיאה במחיקה");
            }
        }


        function logout() {
            sessionStorage.clear();
            localStorage.clear();
            window.location.href = "/auth/login";
        }

        loadLessons();
    </script>
</body>
</html>