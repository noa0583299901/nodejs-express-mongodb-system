<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>בקשת שיעור חדש</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { 
            background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 100%);
            direction: rtl; 
            text-align: right; 
            min-height: 100vh;
            font-family: 'Segoe UI', sans-serif;
        }
        .form-card { 
            background: white; 
            border-radius: 25px; 
            border: none; 
            box-shadow: 0 15px 35px rgba(0,0,0,0.1); 
            padding: 50px; 
            margin-top: 50px;
            border-top: 8px solid #3f51b5;
        }
        .form-label { font-weight: bold; color: #3f51b5; margin-bottom: 8px; }
        .form-control { 
            border-radius: 12px; 
            padding: 14px; 
            border: 1px solid #e0e7ff; 
            background-color: #fcfdfe; 
        }
        .form-control:focus { 
            border-color: #3f51b5; 
            box-shadow: 0 0 0 0.25rem rgba(63, 81, 181, 0.1); 
        }
        .btn-submit { 
            background-color: #3f51b5; 
            color: white; 
            border-radius: 50px; 
            padding: 15px 30px; 
            font-weight: bold; 
            border: none; 
            transition: all 0.3s ease; 
        }
        .btn-submit:hover { 
            background-color: #303f9f; 
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(63, 81, 181, 0.3);
        }
        #errorMsg { display: none; color: #dc3545; text-align: center; margin-bottom: 15px; font-weight: bold; }
    </style>
</head>
<body>

<div class="container mb-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="form-card">
                <h2 class="fw-bold text-dark mb-3 text-center">בקשת שיעור חדש</h2>
                <p class="text-muted text-center mb-5">אנא מלא את פרטי הבקשה והמורה יחזור אליך עם מחיר ואישור</p>

                <div id="errorMsg">שגיאה בשליחת הבקשה. נסה שנית.</div>

                <form id="addLessonForm">
                    <div class="mb-4">
                        <label class="form-label">השם המלא שלך</label>
                        <input type="text" id="studentName" name="studentName" class="form-control" placeholder="הכנס שם מלא" required>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">נושא השיעור</label>
                        <input type="text" id="subject" name="subject" class="form-control" placeholder="לדוגמה: תכנות Node.js, מתמטיקה" required>
                        <small class="text-muted">זה ישמש ככותרת הראשית של השיעור</small>
                    </div>

                    <div class="mb-5">
                        <label class="form-label">פרטים נוספים על הבקשה</label>
                        <textarea id="content" name="content" class="form-control" rows="5" placeholder="מה תרצה ללמוד בשיעור זה?"></textarea>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-submit shadow-sm">שלח בקשה לאישור</button>
                    </div>
                </form>

                <div class="text-center mt-4">
                    <a href="/lessons" class="text-decoration-none text-muted small">← חזרה לרשימת השיעורים</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const token = sessionStorage.getItem("token");
    if (!token) window.location.href = "/auth/login";

  
    const savedName = sessionStorage.getItem("username");
    if (savedName) {
        document.getElementById("studentName").value = savedName;
    }

    document.getElementById("addLessonForm").addEventListener("submit", async (e) => {
        e.preventDefault();
        const errorMsg = document.getElementById("errorMsg");
        errorMsg.style.display = "none";

        const lessonData = {
            studentName: document.getElementById("studentName").value,
            subject: document.getElementById("subject").value,
            content: document.getElementById("content").value
        };

        try {
            const res = await fetch("/lessons/add", {
                method: "POST",
                headers: { 
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + token 
                },
                body: JSON.stringify(lessonData)
            });

            if (res.ok) {
              
                window.location.href = "/lessons";
            } else {
                errorMsg.style.display = "block";
            }
        } catch (err) {
            console.error("Error adding lesson:", err);
            errorMsg.style.display = "block";
        }
    });
</script>

</body>
</html>